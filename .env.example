PB_DB_DRIVER=sqlite
PB_DB_PATH=data/booking.db

# Preferred provider switch (supported: demo, stripe, square)
PB_PAYMENT_PROVIDER=demo
# Legacy alias still supported:
# PB_PAYMENT_MODE=demo

PB_PUBLIC_BASE_URL=http://localhost:8000
PB_APP_KEY=change-me

# Stripe
PB_STRIPE_SECRET_KEY=
PB_STRIPE_PUBLISHABLE_KEY=
PB_STRIPE_WEBHOOK_SECRET=
PB_STRIPE_WEBHOOK_TOLERANCE=300
PB_STRIPE_API_BASE=https://api.stripe.com/v1

# Square
PB_SQUARE_ACCESS_TOKEN=
PB_SQUARE_APPLICATION_ID=
PB_SQUARE_LOCATION_ID=
PB_SQUARE_WEBHOOK_SIGNATURE_KEY=
PB_SQUARE_WEBHOOK_URL=http://localhost:8000/square-webhook.php
PB_SQUARE_API_BASE=https://connect.squareup.com
# Optional Square API version header:
# PB_SQUARE_API_VERSION=2025-04-16
